-- Função Fábrica de Botões
local function CreateButton(name, callback)
	local btn = Instance.new("TextButton", gridC)
	btn.BackgroundColor3 = Colors.BtnOff
	btn.Text = name
	btn.TextColor3 = Colors.Text
	btn.Font = Enum.Font.GothamMedium
	btn.TextSize = 13
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
	
	btn.MouseButton1Click:Connect(function()
		local isActive = callback() -- Chama a função do Core
		
		-- Animação
		if isActive == true then
			TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = Colors.BtnOn}):Play()
		elseif isActive == false then
			TweenService:Create(btn, TweenInfo.new(0.3), {BackgroundColor3 = Colors.BtnOff}):Play()
		else
			-- Clique momentâneo (sem estado on/off)
			TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundColor3 = Colors.Accent}):Play()
			task.wait(0.1)
			TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Colors.BtnOff}):Play()
		end
	end)
end

