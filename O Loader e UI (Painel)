(function() {
    // 1. Criar e Exibir a Tela de Carregamento
    const loader = document.createElement('div');
    loader.id = 'gemini-custom-loader';
    loader.innerHTML = `
        <div class="loader-content">
            <div class="spinner"></div>
            <p>Aplicando Design Premium...</p>
        </div>
    `;
    document.body.appendChild(loader);

    // 2. CSS do Loader e da Nova UI
    const styleId = 'gemini-ultimate-ui';
    if (document.getElementById(styleId)) document.getElementById(styleId).remove();

    const css = `
        /* TELA DE CARREGAMENTO */
        #gemini-custom-loader {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: #1e1e2e; color: white; z-index: 99999;
            display: flex; justify-content: center; align-items: center;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            transition: opacity 0.5s ease;
        }
        .spinner {
            width: 50px; height: 50px; border: 5px solid #313244;
            border-top: 5px solid #89b4fa; border-radius: 50%;
            animation: spin 1s linear infinite; margin: 0 auto 20px;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }

        /* MUDANÇA TOTAL DE DESIGN */
        body, .chat-history, main, .md-content {
            background-color: #11111b !important; /* Dark Mode profundo */
        }

        /* BALÃO DO USUÁRIO + FOTO */
        .user-query-container, [data-test-id="user-query"] {
            display: flex !important;
            flex-direction: row-reverse !important;
            align-items: center !important;
            gap: 15px !important;
            margin: 20px 0 !important;
        }

        .query-content {
            background: linear-gradient(135deg, #89b4fa, #b4befe) !important;
            color: #11111b !important;
            border-radius: 20px 20px 0px 20px !important;
            padding: 15px 25px !important;
            box-shadow: 0 8px 24px rgba(137, 180, 250, 0.2) !important;
            font-weight: 500 !important;
        }

        /* FOTO DE PERFIL (CLONE) */
        img[src*="googleusercontent.com"], .user-avatar {
            width: 50px !important;
            height: 50px !important;
            border-radius: 50% !important;
            border: 3px solid #89b4fa !important;
            transition: transform 0.3s ease;
        }

        /* BALÃO DO GEMINI */
        .model-response-container {
            background: #181825 !important;
            border-radius: 20px 20px 20px 0px !important;
            border: 1px solid #313244 !important;
            padding: 20px !important;
            color: #cdd6f4 !important;
            margin: 15px 0 !important;
        }

        /* BARRA DE DIGITAÇÃO */
        .input-area, .chat-input-container {
            background: #313244 !important;
            border-radius: 40px !important;
            border: 1px solid #45475a !important;
        }
    `;

    const styleSheet = document.createElement("style");
    styleSheet.id = styleId;
    styleSheet.innerText = css;
    document.head.appendChild(styleSheet);

    // 3. Remover o Loader após 2.5 segundos
    setTimeout(() => {
        loader.style.opacity = '0';
        setTimeout(() => loader.remove(), 500);
    }, 2500);

})();
